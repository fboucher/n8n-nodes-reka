{
	"git": {
		"commitMessage": "chore: release v${version}",
		"tagName": "${version}",
		"requireBranch": ["main", "develop"],
		"requireCleanWorkingDir": false
	},
	"github": {
		"release": false
	},
	"npm": {
		"publish": false
	},
	"hooks": {
		"before:init": ["npm run build", "npm run lint"]
	}
}
